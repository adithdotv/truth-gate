# ── TruthGate environment ───────────────────────────────────────
# Copy to .env.local and fill in. All vars are public (NEXT_PUBLIC_*),
# baked into the client bundle — do not put secrets here.

# Required — the deployed TruthGate oracle on Somnia
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Optional — Somnia network (defaults to the Shannon testnet)
NEXT_PUBLIC_SOMNIA_CHAIN_ID=50312
NEXT_PUBLIC_SOMNIA_RPC=https://dream-rpc.somnia.network
NEXT_PUBLIC_SOMNIA_EXPLORER=https://shannon-explorer.somnia.network

# Optional — public site URL used for shareable links / OG image
NEXT_PUBLIC_SITE_URL=https://truth-gate-opal.vercel.app
